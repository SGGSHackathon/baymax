# ── Groq (free at console.groq.com) ──────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Pinecone (free at pinecone.io) ───────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=medical-rag

# ── Neon PostgreSQL ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Redis / Upstash (free at upstash.com) ────────────────────
REDIS_URL="rediss://default:your_redis_password@your-host.upstash.io:6379"

# ── BullMQ Node.js sidecar (runs on same server) ─────────────
BULLMQ_SERVER_URL=http://localhost:3001

# ── whatsapp-web.js server ────────────────────────────────────
WHATSAPP_SERVER_URL=http://localhost:5001

# ── Sarvam.ai Multilingual Translation ───────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here

# ── LangSmith Tracing (optional) ─────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=medical-ai

# ── Redis for Reminders (separate Upstash instance) ──────────
REDIS_REMINDER_URL="rediss://default:your_redis_password@your-host.upstash.io:6379"

# ── Twilio (for escalation calls) ────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Admin ─────────────────────────────────────────────────────
ADMIN_PHONE=+91xxxxxxxxxx
ALLOWED_ORIGIN=*

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24
